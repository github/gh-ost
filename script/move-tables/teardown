#!/bin/bash

# This script removes the four MySQL docker containers in two primary-replica clusters
# expected to be provisioned by the setup script.
#
# Usage:
#   teardown      remove the containers

set -e

GH_OST_ROOT=$(git rev-parse --show-toplevel)
if [[ ":$PATH:" != *":$GH_OST_ROOT:"* ]]; then
    export PATH="${PATH}:${GH_OST_ROOT}/script"
fi

echo "Stopping containers..."
docker stop mysql-source-replica mysql-source-primary mysql-target-replica mysql-target-primary 2>/dev/null || true

echo "Removing containers..."
docker rm -f mysql-source-replica mysql-source-primary mysql-target-replica mysql-target-primary 2>/dev/null || true

echo "Cleaning up Docker resources..."
docker system prune -f
docker volume prune -f